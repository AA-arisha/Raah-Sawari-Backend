generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  RIDER
  DRIVER
  ADMIN
}

enum VehicleType {
  BIKE
  CAR
  RICKSHAW
}

enum RideStatus {
  REQUESTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(RIDER)

  rides     Ride[]   @relation("UserRides")
  driver    Driver?

  createdAt DateTime @default(now())
}

model Driver {
  id            Int         @id @default(autoincrement())

  userId        Int         @unique
  user          User        @relation(fields: [userId], references: [id])

  vehicleType   VehicleType
  isAvailable   Boolean     @default(false)

  currentRideId Int?        @unique
  currentRide   Ride?       @relation("CurrentRide", fields: [currentRideId], references: [id])

  rides         Ride[]      @relation("DriverRides")

  createdAt     DateTime    @default(now())
}

model Ride {
  id            Int         @id @default(autoincrement())

  userId        Int
  driverId      Int?

  user          User        @relation("UserRides", fields: [userId], references: [id])
  driver        Driver?     @relation("DriverRides", fields: [driverId], references: [id])
  assignedDriver Driver?    @relation("CurrentRide")

  pickup        String
  drop          String

  vehicleType   VehicleType
  status        RideStatus  @default(REQUESTED)

  fare          Float?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}